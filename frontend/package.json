{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:host-admin": "ng serve host-admin",
    "start:remote-client": "ng serve remote-client",
    "build": "ng build",
    "build:host-admin": "ng build host-admin",
    "build:remote-client": "ng build remote-client",
    "build:libs": "ng build shared-ui && ng build session-model",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:host-admin": "ng test host-admin --watch=false",
    "test:remote-client": "ng test remote-client --watch=false"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xterm": "^5.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.20",
    "@angular/cli": "^20.3.20",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.0",
    "typescript": "~5.9.2"
  }
}
